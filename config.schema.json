{
  "pluginAlias": "WeBeHome",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": false,
  "schema": {
    "type": "object",
    "required": [
      "name",
      "login",
      "password"
    ],
    "additionalProperties": false,
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "WeBeHome"
      },
      "login": {
        "title": "Username",
        "type": "string"
      },
      "password": {
        "title": "Password",
        "type": "string",
        "format": "password"
      },
      "requestTimeoutMs": {
        "title": "Request Timeout",
        "type": "integer",
        "default": 15000,
        "minimum": 1000,
        "maximum": 60000,
        "description": "How long to wait for a WeBeHome HTTP request before aborting it."
      }
    }
  }
}

{
  "metadata": {
    "name": "WeBeHome Customer API",
    "version": "1.16",
    "source": "https://webehome.com/sv/docs",
    "format": "hand-normalized-json",
    "purpose": "Machine-readable local reference for the WeBeHome Customer API without requiring document extraction libraries."
  },
  "notes": [
    "The Customer API is documented for WeBeHome customers with BASIC or PREMIUM subscriptions.",
    "The Web API uses credential-bearing URL parameters documented by WeBeHome.",
    "Web API data responses are pipe-delimited text unless HtmlTable=yes is requested.",
    "WebServiceAPI responses are XML wrapped in NewDataSet/Table tags.",
    "Dates and times returned by the WebServiceAPI are local to the customer's configured timezone."
  ],
  "workflows": [
    {
      "id": "basicCustomerConfiguration",
      "steps": [
        "Call GetCustomerConfig to discover BaseUnitID values.",
        "Call GetBaseUnitConfig for each BaseUnitID to discover attached active SubUnits."
      ]
    },
    {
      "id": "eventDataPolling",
      "steps": [
        "For first poll per BaseUnit, call GetEventData with LastDataID=0 to receive up to the last 24 hours.",
        "Store the highest DataID returned.",
        "For later polls, call GetEventData with LastDataID set to the last stored DataID."
      ]
    }
  ],
  "transports": {
    "webApi": {
      "baseUrl": "https://webehome.com/API/WebAPI.aspx",
      "method": "GET",
      "functionSelector": "Function",
      "responseFormat": "pipe-delimited text",
      "commonParameters": [
        {
          "name": "LoginName",
          "required": true,
          "type": "string"
        },
        {
          "name": "Password",
          "required": true,
          "type": "string"
        },
        {
          "name": "HtmlTable",
          "required": false,
          "type": "enum",
          "values": [
            "yes",
            "no"
          ],
          "default": "no"
        },
        {
          "name": "Heading",
          "required": false,
          "type": "enum",
          "values": [
            "yes",
            "no"
          ],
          "default": "yes"
        }
      ]
    },
    "publicLogin": {
      "baseUrl": "https://webehome.com/Public/login.aspx",
      "method": "GET",
      "commonParameters": [
        {
          "name": "LoginName",
          "required": true,
          "type": "string"
        },
        {
          "name": "Password",
          "required": true,
          "type": "string"
        },
        {
          "name": "LocationID",
          "required": false,
          "type": "integer",
          "description": "Needed when the user has access to more than one location."
        }
      ]
    },
    "graphImage": {
      "baseUrl": "https://webehome.com/API/GraphImage.ashx",
      "method": "GET",
      "responseFormat": "image/jpeg"
    },
    "eventApi": {
      "baseUrl": "https://webehome.com/API/EventAPI.aspx",
      "method": "GET",
      "parameterDelimiter": "_",
      "notes": [
        "The spec says EventAPI accepts http and https, but http should be avoided.",
        "Arguments are documented with underscore separators because some devices cannot handle ampersand separated query strings."
      ]
    },
    "webServiceApi": {
      "baseUrl": "https://webehome.com/API/WebServiceAPI.asmx",
      "method": "GET_OR_SOAP",
      "responseFormat": "xml"
    }
  },
  "publicLogin": {
    "login": {
      "description": "Login automatically using LoginName and Password.",
      "parameters": [
        "LoginName",
        "Password"
      ]
    },
    "targetPages": {
      "description": "Login and open a specific page.",
      "parameter": "targetPage",
      "values": [
        "status",
        "24hour",
        "cameraLive",
        "cameraArchive"
      ],
      "default": "status"
    },
    "actions": {
      "parameter": "Action",
      "optionalParameters": [
        "ActionOnly",
        "LocationID",
        "ScenarioID"
      ],
      "values": {
        "disarm": {
          "description": "Disarm the system."
        },
        "home": {
          "description": "Set the system to home mode."
        },
        "away": {
          "description": "Set the system to away mode."
        },
        "clear": {
          "description": "Clear status/events."
        },
        "status": {
          "requires": {
            "ActionOnly": "yes"
          }
        },
        "statusdetailed": {
          "requires": {
            "ActionOnly": "yes"
          },
          "returns": [
            "operation mode numeric code",
            "location description",
            "operation mode text",
            "changed by",
            "change date/time",
            "number of alarm and important events"
          ]
        },
        "startscenario": {
          "requires": {
            "ActionOnly": "yes",
            "ScenarioID": "integer"
          }
        }
      }
    }
  },
  "webApiFunctions": [
